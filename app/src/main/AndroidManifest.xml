<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FFTT04M">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/title_listening"
            android:screenOrientation="fullSensor">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".GalleryActivity"
            android:exported="false"
            android:label="@string/title_gallery"
            android:screenOrientation="fullSensor" />

        <activity
            android:name=".ViewerActivity"
            android:exported="false"
            android:label="@string/title_analysis"
            android:screenOrientation="fullSensor" />

        <activity
            android:name=".WaveletActivity"
            android:exported="false"
            android:label="@string/title_wavelet"
            android:screenOrientation="fullSensor" />

        <activity
            android:name=".LatencyActivity"
            android:exported="false"
            android:screenOrientation="fullSensor" />

        <activity
            android:name=".ManualActivity"
            android:exported="false"
            android:label="User Manual"
            android:screenOrientation="fullSensor" />

    </application>

</manifest>