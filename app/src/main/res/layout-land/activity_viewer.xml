<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Sidebar for controls: Left side -->
    <LinearLayout
        android:id="@+id/vSidebar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/viewerFft"
        app:layout_constraintHorizontal_weight="0.4"
        android:clipChildren="false">

        <TextView
            android:id="@+id/vTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_analysis"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btnViewerGalleryTop"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_gallery"
                android:backgroundTint="#FFFF00"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
            <Button
                android:id="@+id/btnViewerListenTop"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="LISTEN"
                android:backgroundTint="#00FFFF"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
            <Button
                android:id="@+id/btnViewerNote"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="NOTE"
                android:backgroundTint="#FFFFFF"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        </LinearLayout>

        <Button
            android:id="@+id/btnViewerPlay"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/btn_play"
            android:backgroundTint="#90EE90"
            android:textColor="#000000"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/fftParamsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <Spinner
                android:id="@+id/vSizeSpinner"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@android:color/transparent" />
            <Spinner
                android:id="@+id/vStepSpinner"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@android:color/transparent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/vSliderContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="54"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- EQ Sliders Only -->
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_100hz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                    <com.google.android.material.slider.Slider android:id="@+id/vEq100" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                    <TextView android:id="@+id/txtEq100Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false" android:gravity="center"/>
                </FrameLayout>
            </LinearLayout>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_300hz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                    <com.google.android.material.slider.Slider android:id="@+id/vEq300" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                    <TextView android:id="@+id/txtEq300Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false" android:gravity="center"/>
                </FrameLayout>
            </LinearLayout>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_1khz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                    <com.google.android.material.slider.Slider android:id="@+id/vEq1k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                    <TextView android:id="@+id/txtEq1kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false" android:gravity="center"/>
                </FrameLayout>
            </LinearLayout>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_3khz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                    <com.google.android.material.slider.Slider android:id="@+id/vEq3k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                    <TextView android:id="@+id/txtEq3kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false" android:gravity="center"/>
                </FrameLayout>
            </LinearLayout>
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_8khz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                    <com.google.android.material.slider.Slider android:id="@+id/vEq8k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                    <TextView android:id="@+id/txtEq8kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false" android:gravity="center"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Stubs with correct types to avoid ClassCastException -->
        <LinearLayout android:id="@+id/vCustomToolbar" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:orientation="horizontal"/>
        <LinearLayout android:id="@+id/vTopControlsRow1" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:orientation="horizontal"/>
        <Spinner android:id="@+id/vColorSpinner" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <Spinner android:id="@+id/vBlurSpinner" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <Button android:id="@+id/btnViewerSweep" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <Button android:id="@+id/btnViewerWavelet" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <LinearLayout android:id="@+id/vFilterControlsLayout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:orientation="horizontal"/>
        <com.google.android.material.slider.Slider android:id="@+id/vSliderNoiseFilter" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <com.google.android.material.slider.Slider android:id="@+id/vSliderNoiseRise" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <com.google.android.material.slider.Slider android:id="@+id/vSliderNoiseFall" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/vTxtFilterValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/vTxtRiseValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/vTxtFallValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    </LinearLayout>

    <!-- Map Area: Right side, Square 1:1 -->
    <com.example.FFTT04M.FFTHeatMapView
        android:id="@+id/viewerFft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="0.6" />

    <ProgressBar
        android:id="@+id/viewerProgress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:elevation="8dp"
        android:indeterminateTint="#FF69B4"
        app:layout_constraintStart_toStartOf="@+id/viewerFft"
        app:layout_constraintEnd_toEndOf="@+id/viewerFft"
        app:layout_constraintTop_toTopOf="@+id/viewerFft"
        app:layout_constraintBottom_toBottomOf="@+id/viewerFft" />

    <!-- Placeholder stubs -->
    <View android:id="@+id/gutter1" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <View android:id="@+id/gutter2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/viewerGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>
