<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- All controls invisible in landscape wavelet -->
    <LinearLayout android:id="@+id/waveletToolbar" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:orientation="horizontal" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <Button android:id="@+id/btnWaveletGalleryTop" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <Button android:id="@+id/btnWaveletListenTop" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <Button android:id="@+id/btnWaveletStop" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>

    <!-- Exhaustive stubs for WaveletActivity -->
    <Spinner android:id="@+id/waveletFamilySpinner" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <Spinner android:id="@+id/waveletBoundarySpinner" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <CheckBox android:id="@+id/checkSoftThresh" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <CheckBox android:id="@+id/checkWPT" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <CheckBox android:id="@+id/checkLogScale" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <CheckBox android:id="@+id/checkLocalNorm" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <CheckBox android:id="@+id/checkReconstruct" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <CheckBox android:id="@+id/checkCWT" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    <com.google.android.material.slider.Slider android:id="@+id/sliderOrder" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <com.google.android.material.slider.Slider android:id="@+id/sliderLevel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <com.google.android.material.slider.Slider android:id="@+id/sliderSampling" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <com.google.android.material.slider.Slider android:id="@+id/sliderThreshold" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <com.google.android.material.slider.Slider android:id="@+id/sliderColor" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    <TextView android:id="@+id/txtLevelValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/txtOrderValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/txtSamplingValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/txtThresholdValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/txtColorValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    <!-- Map Area: Square 1:1, centered horizontally, full height -->
    <com.example.FFTT04M.WaveletView
        android:id="@+id/waveletView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
