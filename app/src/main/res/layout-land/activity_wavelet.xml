<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Map Area: right, square 1:1 sized by height. -->
    <com.example.FFTT04M.WaveletView
        android:id="@+id/waveletView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Control sidebar: left, fills the space beside the square map. -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="6dp"
        android:background="#222222"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/waveletView"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:weightSum="3">
            <Button android:id="@+id/btnWaveletGalleryTop" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" android:text="@string/btn_gallery" android:backgroundTint="#FFFF00" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:minWidth="0dp" android:minHeight="0dp" android:padding="6dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
            <Button android:id="@+id/btnWaveletListenTop" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" android:text="LISTEN" android:backgroundTint="#00FFFF" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:minWidth="0dp" android:minHeight="0dp" android:padding="6dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
            <!-- COLOR: button that opens a radio-choice dialog (like Enhance) -->
            <Button android:id="@+id/btnWaveletColor" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="COLOR" android:backgroundTint="#FF00FF" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:minWidth="0dp" android:minHeight="0dp" android:padding="6dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/waveletTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabTextColor="#888888"
            app:tabSelectedTextColor="#FFFFFF"
            app:tabIndicatorColor="#FFFF00">
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SETUP"/>
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SLIDERS"/>
        </com.google.android.material.tabs.TabLayout>

        <!-- ===== Page 0: SETUP ===== -->
        <LinearLayout
            android:id="@+id/pageWaveletSetup"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- MODE first; FAMILY repopulates with mode-relevant choices; then BND (mirrors portrait) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                <TextView android:layout_width="64dp" android:layout_height="wrap_content" android:text="MODE" android:textColor="#FFFF00" android:textSize="12sp" android:textStyle="bold"/>
                <Spinner android:id="@+id/waveletModeSpinner" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:backgroundTint="#FFFFFF" android:layout_marginStart="4dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                <TextView android:layout_width="64dp" android:layout_height="wrap_content" android:text="FAMILY" android:textColor="#FFFF00" android:textSize="12sp" android:textStyle="bold"/>
                <Spinner android:id="@+id/waveletFamilySpinner" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:backgroundTint="#FFFFFF" android:layout_marginStart="4dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                <TextView android:layout_width="64dp" android:layout_height="wrap_content" android:text="BND" android:textColor="#FFFF00" android:textSize="12sp" android:textStyle="bold"/>
                <Spinner android:id="@+id/waveletBoundarySpinner" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:backgroundTint="#FFFFFF" android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Legacy status (GONE): shown inline next to SOFT instead -->
            <TextView
                android:id="@+id/txtSafetyStatus"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:text="" />

            <!-- Threshold row; safety indicator sits to the right of SOFT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <TextView android:layout_width="64dp" android:layout_height="wrap_content" android:text="Threshold" android:textColor="#AAAAAA" android:textSize="11sp" android:textStyle="bold" android:maxLines="1"/>
                <CheckBox android:id="@+id/checkSoftThresh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SOFT" android:textColor="#FFFFFF" android:buttonTint="#FFFFFF" android:textSize="11sp" android:maxLines="1" android:layout_marginStart="4dp" />
                <TextView android:id="@+id/txtModeSafeIndicator" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="" android:textColor="#FFCC99" android:textSize="10sp" android:gravity="end" android:layout_marginStart="4dp" android:layout_marginEnd="2dp" android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView android:layout_width="64dp" android:layout_height="wrap_content" android:text="View" android:textColor="#AAAAAA" android:textSize="11sp" android:textStyle="bold" android:maxLines="1"/>
                <CheckBox android:id="@+id/checkLogScale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOG" android:textColor="#FFFFFF" android:buttonTint="#FFFFFF" android:textSize="11sp" android:maxLines="1" android:layout_marginEnd="8dp" />
                <CheckBox android:id="@+id/checkLocalNorm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="L-NORM" android:textColor="#FFFFFF" android:buttonTint="#FFFFFF" android:textSize="11sp" android:maxLines="1" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== Page 1: SLIDERS ===== -->
        <LinearLayout
            android:id="@+id/pageWaveletSliders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="4"
            android:visibility="gone"
            android:layout_marginTop="2dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                <TextView android:layout_width="match_parent" android:layout_height="28dp" android:gravity="center" android:text="LEVEL" android:maxLines="1" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider android:id="@+id/sliderLevel" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="1.0" android:valueTo="8.0" android:value="4.0" android:stepSize="1.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#333333" android:layout_gravity="center" />
                    <TextView android:id="@+id/txtLevelValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                <TextView android:layout_width="match_parent" android:layout_height="28dp" android:gravity="center" android:text="ORDER" android:maxLines="1" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider android:id="@+id/sliderOrder" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="1.0" android:valueTo="10.0" android:value="1.0" android:stepSize="1.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#333333" android:layout_gravity="center" />
                    <TextView android:id="@+id/txtOrderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                <TextView android:layout_width="match_parent" android:layout_height="28dp" android:gravity="center" android:text="SAMPLE" android:maxLines="1" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider android:id="@+id/sliderSampling" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="1000.0" android:valueTo="44100.0" android:value="44100.0" android:stepSize="1.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:thumbColor="#FFFFFF" app:trackColorActive="#AAAAAA" app:trackColorInactive="#333333" android:layout_gravity="center" />
                    <TextView android:id="@+id/txtSamplingValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="44k" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                <TextView android:layout_width="match_parent" android:layout_height="28dp" android:gravity="center" android:text="THRESH" android:maxLines="1" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider android:id="@+id/sliderThreshold" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="9.0" android:value="4.0" android:stepSize="1.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#333333" android:layout_gravity="center" />
                    <TextView android:id="@+id/txtThresholdValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.1" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Stub: btnWaveletStop removed from portrait UI but referenced in code -->
    <Button android:id="@+id/btnWaveletStop" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
