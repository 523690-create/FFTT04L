<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Row 1: Title and QUIT (4% Height) -->
    <LinearLayout
        android:id="@+id/customToolbar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintHeight_percent="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_listening"
            style="@style/TextHeading" />

        <Button
            android:id="@+id/btnQuitTop"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/btn_quit"
            android:backgroundTint="#FF0000"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
    </LinearLayout>

    <!-- Gutter 1: 1% Height -->
    <View
        android:id="@+id/gutterTop"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.01"
        app:layout_constraintTop_toBottomOf="@+id/customToolbar" />

    <!-- Row 2: Mic and Color (4% Height) -->
    <LinearLayout
        android:id="@+id/micAndColorLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:weightSum="100"
        app:layout_constraintHeight_percent="0.04"
        app:layout_constraintTop_toBottomOf="@+id/gutterTop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Spinner
            android:id="@+id/micSpinner"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="65"
            android:layout_marginEnd="2dp"
            android:background="@android:color/transparent"
            android:overlapAnchor="false" />
        <Spinner
            android:id="@+id/colorSpinner"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="35"
            android:layout_marginStart="2dp"
            android:background="@android:color/transparent"
            android:overlapAnchor="false" />
    </LinearLayout>

    <!-- Gutter 2: 1% Height -->
    <View
        android:id="@+id/gutterMid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.01"
        app:layout_constraintTop_toBottomOf="@+id/micAndColorLayout" />

    <!-- Row 3: Latency and Gallery (4% Height) -->
    <LinearLayout
        android:id="@+id/mainButtonsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:weightSum="100"
        app:layout_constraintHeight_percent="0.04"
        app:layout_constraintTop_toBottomOf="@+id/gutterMid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnLatency"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="70"
            android:text="@string/btn_latency"
            android:backgroundTint="#D3D3D3"
            android:textColor="#000000"
            android:layout_marginEnd="2dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp" />

        <Button
            android:id="@+id/btnGallery"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="30"
            android:text="@string/btn_gallery"
            android:backgroundTint="#FFFF00"
            android:textColor="#000000"
            android:layout_marginStart="2dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp" />
    </LinearLayout>

    <!-- Gutter 3: 1% Height -->
    <View
        android:id="@+id/gutterFft"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.01"
        app:layout_constraintTop_toBottomOf="@+id/mainButtonsLayout" />

    <!-- FFT Container: Square 1:1, Flush Sides -->
    <FrameLayout
        android:id="@+id/fftContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@+id/gutterFft"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.example.FFTT04M.FFTHeatMapView
            android:id="@+id/fftHeatMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#111111" />

        <com.example.FFTT04M.CropOverlayView
            android:id="@+id/cropOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.70" />

    <!-- Controls Overlay Container -->
    <FrameLayout
        android:id="@+id/controlsOverlayRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#222222"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideline"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Standard Sliders Window -->
        <LinearLayout
            android:id="@+id/controlsWindow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="4dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/sliderContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:weightSum="88"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/eqSlidersLayout"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="54"
                    android:orientation="horizontal"
                    android:weightSum="54"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_100hz" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/eq100" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                            <TextView android:id="@+id/txtEqValue100" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
                        </FrameLayout>
                    </LinearLayout>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_300hz" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/eq300" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                            <TextView android:id="@+id/txtEqValue300" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
                        </FrameLayout>
                    </LinearLayout>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_1khz" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/eq1k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                            <TextView android:id="@+id/txtEqValue1k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
                        </FrameLayout>
                    </LinearLayout>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_3khz" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/eq3k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                            <TextView android:id="@+id/txtEqValue3k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
                        </FrameLayout>
                    </LinearLayout>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_8khz" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/eq8k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                            <TextView android:id="@+id/txtEqValue8k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2" />

                <LinearLayout
                    android:id="@+id/filterControlsLayout"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="32"
                    android:orientation="horizontal"
                    android:weightSum="32"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_filter_percent" android:textColor="#00FFFF" android:textSize="9sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:lines="2" android:includeFontPadding="false"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/sliderNoiseFilter" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="1.0" android:value="0.0" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#007F7F" android:layout_gravity="top|center_horizontal"/>
                            <TextView android:id="@+id/txtFilterValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0pct" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
                        </FrameLayout>
                    </LinearLayout>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_rise_time" android:textColor="#00FFFF" android:textSize="9sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:lines="2" android:includeFontPadding="false"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/sliderNoiseRise" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="3.0" android:value="1.7" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#007F7F" android:layout_gravity="top|center_horizontal"/>
                            <TextView android:id="@+id/txtRiseValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0ms" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
                        </FrameLayout>
                    </LinearLayout>
                    <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                        <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_fall_time" android:textColor="#00FFFF" android:textSize="9sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:lines="2" android:includeFontPadding="false"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/sliderNoiseFall" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="3.0" android:value="2.3" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#007F7F" android:layout_gravity="top|center_horizontal"/>
                            <TextView android:id="@+id/txtFallValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0ms" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- Save/Esc Superimposed Over Sliders -->
        <LinearLayout
            android:id="@+id/saveEscContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="3"
            android:gravity="center"
            android:background="#DD000000"
            android:visibility="gone"
            android:padding="20dp">
            <Button
                android:id="@+id/btnSaveInRow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:text="@string/btn_save"
                android:backgroundTint="#90EE90"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_margin="8dp" />
            <Button
                android:id="@+id/btnEscInRow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/btn_esc"
                android:backgroundTint="#FFA500"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_margin="8dp" />
        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
