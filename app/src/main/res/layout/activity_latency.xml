<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LATENCY MEASUREMENT"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnMeasureLatency"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:text="START MEASUREMENT (CHIRP)"
        android:backgroundTint="#AA0000"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/txtLatencyResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Result: -- ms"
        android:textColor="#00FF00"
        android:textSize="24sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Instructions:\n1. Increase volume.\n2. Place mic near speaker.\n3. Press Start.\nA chirp will play and be recorded to measure round-trip latency."
        android:textColor="#888888"
        android:textSize="14sp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/btnLatencyBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BACK"
        android:layout_gravity="start"/>

</LinearLayout>
