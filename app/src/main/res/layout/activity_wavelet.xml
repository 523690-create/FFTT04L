<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/wCustomToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_wavelet"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <Button
            android:id="@+id/btnWaveletGalleryTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_gallery"
            android:backgroundTint="#FFFF00"
            android:textColor="#000000"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Button
            android:id="@+id/btnWaveletListenTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LISTEN"
            android:backgroundTint="#00FFFF"
            android:textColor="#000000"
            android:textSize="10sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
    </LinearLayout>

    <com.example.FFTT04M.WaveletView
        android:id="@+id/waveletView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        app:layout_constraintBottom_toTopOf="@+id/waveletGuideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/waveletGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.45" />

    <LinearLayout
        android:id="@+id/waveletControls"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="4dp"
        android:background="#222222"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/waveletGuideline">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FAM" android:textColor="#FFFF00" android:textSize="10sp" android:textStyle="bold"/>
                <Spinner
                    android:id="@+id/waveletFamilySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#FFFFFF"
                    android:layout_margin="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BND" android:textColor="#FFFF00" android:textSize="10sp" android:textStyle="bold"/>
                <Spinner
                    android:id="@+id/waveletBoundarySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#FFFFFF"
                    android:layout_margin="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MODE" android:textColor="#FFFF00" android:textSize="10sp" android:textStyle="bold"/>
                <Spinner
                    android:id="@+id/waveletModeSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#FFFFFF"
                    android:layout_margin="2dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/txtSafetyStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="9sp"
            android:gravity="center"
            android:paddingVertical="1dp"
            android:singleLine="true"
            android:text="" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="THRESH:" android:textColor="#AAAAAA" android:textSize="10sp" android:textStyle="bold" android:layout_marginEnd="6dp"/>

            <CheckBox
                android:id="@+id/checkSoftThresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOFT"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF"
                android:textSize="10sp"
                android:layout_marginEnd="10dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VIEW:" android:textColor="#AAAAAA" android:textSize="10sp" android:textStyle="bold" android:layout_marginEnd="6dp"/>

            <CheckBox
                android:id="@+id/checkLogScale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOG"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF"
                android:textSize="10sp"
                android:layout_marginEnd="4dp" />

            <CheckBox
                android:id="@+id/checkLocalNorm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="L-NORM"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF"
                android:textSize="10sp"
                android:layout_marginEnd="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnWaveletStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STOP"
                android:backgroundTint="#FF0000"
                android:textColor="#FFFFFF"
                android:layout_margin="2dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:minHeight="32dp"
                android:minWidth="0dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5"
            android:layout_marginTop="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="24dp" android:text="LVL" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                        android:id="@+id/sliderLevel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="1.0"
                        android:valueTo="8.0"
                        android:value="4.0"
                        android:stepSize="1.0"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="32dp"
                        app:thumbRadius="16dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#00FF00"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center" />
                    <TextView android:id="@+id/txtLevelValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="24dp" android:text="ORD" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                        android:id="@+id/sliderOrder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="1.0"
                        android:valueTo="10.0"
                        android:value="1.0"
                        android:stepSize="1.0"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="32dp"
                        app:thumbRadius="16dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#00FF00"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center" />
                    <TextView android:id="@+id/txtOrderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="24dp" android:text="FS" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                        android:id="@+id/sliderSampling"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="1000.0"
                        android:valueTo="44100.0"
                        android:value="44100.0"
                        android:stepSize="1.0"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="32dp"
                        app:thumbRadius="16dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#AAAAAA"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center" />
                    <TextView android:id="@+id/txtSamplingValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="44k" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="24dp" android:text="THR" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                        android:id="@+id/sliderThreshold"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="0.0"
                        android:valueTo="9.0"
                        android:value="4.0"
                        android:stepSize="1.0"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="32dp"
                        app:thumbRadius="16dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#00FFFF"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center" />
                    <TextView android:id="@+id/txtThresholdValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.1" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <Spinner
                    android:id="@+id/vColorSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:overlapAnchor="false" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
