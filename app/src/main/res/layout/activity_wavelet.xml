<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/wCustomToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:weightSum="100">

        <Button
            android:id="@+id/btnWaveletGalleryTop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="33"
            android:text="@string/btn_gallery"
            android:backgroundTint="#FFFF00"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Button
            android:id="@+id/btnWaveletListenTop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="33"
            android:text="LISTEN"
            android:backgroundTint="#00FFFF"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <!-- COLOR: now a button that opens a radio-choice dialog (like Enhance) -->
        <Button
            android:id="@+id/btnWaveletColor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="34"
            android:text="COLOR"
            android:backgroundTint="#FF00FF"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
    </LinearLayout>

    <!-- Display gets a fixed 55% of screen height; the remaining ~45% holds the top bar,
         tab bar, and controls. (Guideline below is now unused but kept to avoid churn.) -->
    <com.example.FFTT04M.WaveletView
        android:id="@+id/waveletView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        app:layout_constraintHeight_percent="0.55"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/wCustomToolbar" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/waveletGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.45" />

    <LinearLayout
        android:id="@+id/waveletControls"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="4dp"
        android:paddingBottom="12dp"
        android:background="#222222"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/waveletView">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/waveletTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#000000"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabTextColor="#888888"
            app:tabSelectedTextColor="#FFFFFF"
            app:tabIndicatorColor="#FFFF00">
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SETUP"/>
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SLIDERS"/>
        </com.google.android.material.tabs.TabLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ===== Page 0: SETUP (families, mode, threshold/view toggles, no STOP) ===== -->
                <LinearLayout
                    android:id="@+id/pageWaveletSetup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Each spinner on its own full-width row: label left, wide spinner right -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="FAM" android:textColor="#FFFF00" android:textSize="14sp" android:textStyle="bold"/>
                        <Spinner android:id="@+id/waveletFamilySpinner" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:backgroundTint="#FFFFFF" android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="BND" android:textColor="#FFFF00" android:textSize="14sp" android:textStyle="bold"/>
                        <Spinner android:id="@+id/waveletBoundarySpinner" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:backgroundTint="#FFFFFF" android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="MODE" android:textColor="#FFFF00" android:textSize="14sp" android:textStyle="bold"/>
                        <Spinner android:id="@+id/waveletModeSpinner" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:backgroundTint="#FFFFFF" android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <!-- Legacy status (GONE): the mode/FS safety text is now shown inline next to SOFT. -->
                    <TextView
                        android:id="@+id/txtSafetyStatus"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone"
                        android:text="" />

                    <!-- THRESH on its own line; safety indicator sits to the right of SOFT -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="4dp" android:layout_marginTop="2dp">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Threshold" android:textColor="#AAAAAA" android:textSize="13sp" android:textStyle="bold" android:maxLines="1"/>
                        <CheckBox android:id="@+id/checkSoftThresh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SOFT" android:textColor="#FFFFFF" android:buttonTint="#FFFFFF" android:textSize="14sp" android:maxLines="1" android:layout_marginStart="8dp" />
                        <TextView android:id="@+id/txtModeSafeIndicator" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="" android:textColor="#FFCC99" android:textSize="11sp" android:gravity="end" android:layout_marginStart="6dp" android:layout_marginEnd="4dp" android:maxLines="1" android:ellipsize="end" />
                    </LinearLayout>

                    <!-- VIEW on its own line -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="4dp" android:layout_marginTop="2dp">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="View" android:textColor="#AAAAAA" android:textSize="13sp" android:textStyle="bold" android:maxLines="1"/>
                        <CheckBox android:id="@+id/checkLogScale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOG" android:textColor="#FFFFFF" android:buttonTint="#FFFFFF" android:textSize="14sp" android:maxLines="1" android:layout_marginStart="8dp" android:layout_marginEnd="20dp" />
                        <CheckBox android:id="@+id/checkLocalNorm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="L-NORM" android:textColor="#FFFFFF" android:buttonTint="#FFFFFF" android:textSize="14sp" android:maxLines="1" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== Page 1: SLIDERS (level, order, sampling, threshold, no color) =====
                     Fills the viewport height (ScrollView has fillViewport) so the sliders and
                     their value labels are as tall/large as the control area allows. -->
                <LinearLayout
                    android:id="@+id/pageWaveletSliders"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:visibility="gone"
                    android:layout_marginTop="2dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:id="@+id/lblWavLevel" android:layout_width="wrap_content" android:layout_height="24dp" android:text="LEVEL" android:maxLines="1" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                                android:id="@+id/sliderLevel"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:valueFrom="1.0"
                                android:valueTo="8.0"
                                android:value="4.0"
                                android:stepSize="1.0"
                                android:orientation="vertical"
                                app:labelBehavior="gone"
                                app:trackHeight="32dp"
                                app:thumbRadius="16dp"
                                app:thumbColor="#FFFFFF"
                                app:trackColorActive="#00FF00"
                                app:trackColorInactive="#333333"
                                android:layout_gravity="center" />
                            <TextView android:id="@+id/txtLevelValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:id="@+id/lblWavOrder" android:layout_width="wrap_content" android:layout_height="24dp" android:text="ORDER" android:maxLines="1" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                                android:id="@+id/sliderOrder"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:valueFrom="1.0"
                                android:valueTo="10.0"
                                android:value="1.0"
                                android:stepSize="1.0"
                                android:orientation="vertical"
                                app:labelBehavior="gone"
                                app:trackHeight="32dp"
                                app:thumbRadius="16dp"
                                app:thumbColor="#FFFFFF"
                                app:trackColorActive="#00FF00"
                                app:trackColorInactive="#333333"
                                android:layout_gravity="center" />
                            <TextView android:id="@+id/txtOrderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:id="@+id/lblWavSampling" android:layout_width="wrap_content" android:layout_height="24dp" android:text="SAMPLE" android:maxLines="1" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                                android:id="@+id/sliderSampling"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:valueFrom="1000.0"
                                android:valueTo="44100.0"
                                android:value="44100.0"
                                android:stepSize="1.0"
                                android:orientation="vertical"
                                app:labelBehavior="gone"
                                app:trackHeight="32dp"
                                app:thumbRadius="16dp"
                                app:thumbColor="#FFFFFF"
                                app:trackColorActive="#AAAAAA"
                                app:trackColorInactive="#333333"
                                android:layout_gravity="center" />
                            <TextView android:id="@+id/txtSamplingValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="44k" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:id="@+id/lblWavThreshold" android:layout_width="wrap_content" android:layout_height="24dp" android:text="THRESH" android:maxLines="1" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                                android:id="@+id/sliderThreshold"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:valueFrom="0.0"
                                android:valueTo="9.0"
                                android:value="4.0"
                                android:stepSize="1.0"
                                android:orientation="vertical"
                                app:labelBehavior="gone"
                                app:trackHeight="32dp"
                                app:thumbRadius="16dp"
                                app:thumbColor="#FFFFFF"
                                app:trackColorActive="#00FFFF"
                                app:trackColorInactive="#333333"
                                android:layout_gravity="center" />
                            <TextView android:id="@+id/txtThresholdValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.1" android:textColor="#000000" android:textSize="9sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
