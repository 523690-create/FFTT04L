<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Top Bar: 0.11 of allowance -->
    <LinearLayout
        android:id="@+id/vCustomToolbar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.11"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#000000"
        android:paddingHorizontal="2dp"
        android:weightSum="100">

        <Button
            android:id="@+id/btnViewerGalleryTop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="20"
            android:text="@string/btn_gallery"
            android:backgroundTint="#FFFF00"
            android:textColor="#000000"
            android:textSize="8sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Button
            android:id="@+id/btnViewerListenTop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="20"
            android:text="LISTEN"
            android:backgroundTint="#00FFFF"
            android:textColor="#000000"
            android:textSize="8sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Button
            android:id="@+id/btnViewerWavelet"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="20"
            android:text="@string/btn_wave"
            android:backgroundTint="#FFFF00"
            android:textColor="#000000"
            android:textSize="8sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Button
            android:id="@+id/btnViewerNote"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="20"
            android:text="NOTE"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:textSize="8sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Button
            android:id="@+id/btnViewerPlay"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="20"
            android:text="@string/btn_play"
            android:backgroundTint="#90EE90"
            android:textColor="#000000"
            android:textSize="8sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
    </LinearLayout>

    <!-- FFT Square: fixed height = width -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111111">

        <com.example.FFTT04M.FFTHeatMapView
            android:id="@+id/viewerFft"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1" />

        <ProgressBar
            android:id="@+id/viewerProgress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            android:elevation="8dp"
            android:indeterminateTint="#FF69B4"
            app:layout_constraintStart_toStartOf="@+id/viewerFft"
            app:layout_constraintEnd_toEndOf="@+id/viewerFft"
            app:layout_constraintTop_toTopOf="@+id/viewerFft"
            app:layout_constraintBottom_toBottomOf="@+id/viewerFft" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Tab Bar: 0.11 of allowance -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/viewerTabs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.11"
        android:background="#000000"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextColor="#888888"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#FF69B4">
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EQ"/>
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FILTER"/>
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DISPLAY"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- Pages: 0.78 of allowance (total 1.0 excluding FFT) -->
    <FrameLayout
        android:id="@+id/pageContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.78">

        <!-- Page 0: EQ -->
        <LinearLayout
            android:id="@+id/pageEq"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="4dp">
            <!-- Header row: band labels with ample vertical space -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.35"
                android:orientation="horizontal"
                android:weightSum="100">
                <TextView android:id="@+id/lblEq100" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:text="@string/label_100hz" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" android:includeFontPadding="false"/>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" />
                <TextView android:id="@+id/lblEq300" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:text="@string/label_300hz" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" android:includeFontPadding="false"/>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" />
                <TextView android:id="@+id/lblEq1k" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:text="@string/label_1khz" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" android:includeFontPadding="false"/>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" />
                <TextView android:id="@+id/lblEq3k" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:text="@string/label_3khz" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" android:includeFontPadding="false"/>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" />
                <TextView android:id="@+id/lblEq8k" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:text="@string/label_8khz" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" android:includeFontPadding="false"/>
            </LinearLayout>
            <!-- Sliders row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.65"
                android:orientation="horizontal"
                android:weightSum="100">
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:orientation="vertical">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider android:id="@+id/vEq100" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" android:stepSize="10.0"/>
                        <TextView android:id="@+id/txtEq100Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:orientation="vertical">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider android:id="@+id/vEq300" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" android:stepSize="10.0"/>
                        <TextView android:id="@+id/txtEq300Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:orientation="vertical">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider android:id="@+id/vEq1k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" android:stepSize="10.0"/>
                        <TextView android:id="@+id/txtEq1kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:orientation="vertical">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider android:id="@+id/vEq3k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" android:stepSize="10.0"/>
                        <TextView android:id="@+id/txtEq3kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="15" android:orientation="vertical">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider android:id="@+id/vEq8k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" android:stepSize="10.0"/>
                        <TextView android:id="@+id/txtEq8kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Page 1: FILTER -->
        <LinearLayout
            android:id="@+id/pageFilter"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="4dp"
            android:visibility="gone">
            <!-- Header row: filter labels with ample vertical space -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.25"
                android:orientation="horizontal"
                android:weightSum="100">
                <TextView android:id="@+id/lblFilterPercent" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="25" android:text="@string/label_filter_percent" android:textColor="#00FFFF" android:textStyle="bold" android:gravity="center" android:includeFontPadding="false"/>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="8" />
                <TextView android:id="@+id/lblFilterRise" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="25" android:text="@string/label_rise_time" android:textColor="#00FFFF" android:textStyle="bold" android:gravity="center" android:includeFontPadding="false"/>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="8" />
                <TextView android:id="@+id/lblFilterFall" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="25" android:text="@string/label_fall_time" android:textColor="#00FFFF" android:textStyle="bold" android:gravity="center" android:includeFontPadding="false"/>
            </LinearLayout>
            <!-- Sliders row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.65"
                android:orientation="horizontal"
                android:weightSum="100">
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="25" android:orientation="vertical">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider android:id="@+id/vSliderNoiseFilter" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="1.0" android:value="0.0" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone"/>
                        <TextView android:id="@+id/vTxtFilterValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0pct" android:textColor="#000000" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="8" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="25" android:orientation="vertical">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider android:id="@+id/vSliderNoiseRise" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="3.0" android:value="1.7" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone"/>
                        <TextView android:id="@+id/vTxtRiseValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0ms" android:textColor="#000000" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="8" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="25" android:orientation="vertical">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider android:id="@+id/vSliderNoiseFall" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="3.0" android:value="2.3" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone"/>
                        <TextView android:id="@+id/vTxtFallValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0ms" android:textColor="#000000" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Page 2: DISPLAY (Dynamic Heights) -->
        <LinearLayout
            android:id="@+id/pageDisplay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:visibility="gone"
            android:weightSum="0.78">

            <Spinner
                android:id="@+id/vSizeSpinner"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.11"
                android:layout_marginBottom="2dp"
                android:background="@android:color/transparent"
                android:overlapAnchor="false" />

            <Spinner
                android:id="@+id/vStepSpinner"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.11"
                android:layout_marginBottom="2dp"
                android:background="@android:color/transparent"
                android:overlapAnchor="false" />

            <Button
                android:id="@+id/btnViewerSweep"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.11"
                android:layout_marginBottom="2dp"
                android:text="@string/sweep_off"
                android:backgroundTint="#FF69B4"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:minWidth="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Spinner
                android:id="@+id/vBlurSpinner"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.11"
                android:layout_marginBottom="2dp"
                android:background="@android:color/transparent"
                android:overlapAnchor="false" />

            <!-- COLOR: button that opens the shared gradient-swatch colour picker -->
            <Button
                android:id="@+id/btnViewerColor"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.11"
                android:layout_marginBottom="2dp"
                android:text="COLOR"
                android:backgroundTint="#FF00FF"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:minWidth="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

            <!-- TIME GRID: multi-pick overlay (1 s thick / 100 ms thin), independent of BLUR -->
            <Button
                android:id="@+id/btnViewerGrid"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.11"
                android:layout_marginBottom="2dp"
                android:text="TIME GRID"
                android:backgroundTint="#9C27B0"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:minWidth="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

            <Spinner
                android:id="@+id/vEnhanceSpinner"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0"
                android:visibility="gone"
                android:overlapAnchor="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.12" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
