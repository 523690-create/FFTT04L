<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Top Bar: 4% height -->
    <LinearLayout
        android:id="@+id/vCustomToolbar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#000000"
        android:paddingHorizontal="2dp"
        app:layout_constraintHeight_percent="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:weightSum="100">

        <Button
            android:id="@+id/btnViewerGalleryTop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="14"
            android:text="@string/btn_gallery"
            android:backgroundTint="#FFFF00"
            android:textColor="#000000"
            android:textSize="7sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Button
            android:id="@+id/btnViewerListenTop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="14"
            android:text="LISTEN"
            android:backgroundTint="#00FFFF"
            android:textColor="#000000"
            android:textSize="7sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Button
            android:id="@+id/btnViewerWavelet"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="14"
            android:text="@string/btn_wave"
            android:backgroundTint="#FFFF00"
            android:textColor="#000000"
            android:textSize="7sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Spinner
            android:id="@+id/vColorSpinner"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="19"
            android:background="@android:color/transparent"
            android:overlapAnchor="false" />

        <Button
            android:id="@+id/btnViewerNote"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="14"
            android:text="NOTE"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:textSize="7sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <Button
            android:id="@+id/btnViewerPlay"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="14"
            android:text="@string/btn_play"
            android:backgroundTint="#90EE90"
            android:textColor="#000000"
            android:textSize="7sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
    </LinearLayout>

    <View
        android:id="@+id/gutter1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.01"
        app:layout_constraintTop_toBottomOf="@+id/vCustomToolbar" />

    <com.example.FFTT04M.FFTHeatMapView
        android:id="@+id/viewerFft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gutter1"
        app:layout_constraintDimensionRatio="1:1" />

    <ProgressBar
        android:id="@+id/viewerProgress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:elevation="8dp"
        android:indeterminateTint="#FF69B4"
        app:layout_constraintStart_toStartOf="@+id/viewerFft"
        app:layout_constraintEnd_toEndOf="@+id/viewerFft"
        app:layout_constraintTop_toTopOf="@+id/viewerFft"
        app:layout_constraintBottom_toBottomOf="@+id/viewerFft" />

    <View
        android:id="@+id/gutter2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.01"
        app:layout_constraintTop_toBottomOf="@+id/viewerFft" />

    <!-- Tabs make every control group reachable without crowding the screen. -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/viewerTabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#000000"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextColor="#888888"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#FF69B4"
        app:layout_constraintTop_toBottomOf="@+id/gutter2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EQ"/>
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FILTER"/>
        <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DISPLAY"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- ===== Page 0: EQ ===== -->
    <LinearLayout
        android:id="@+id/pageEq"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:weightSum="54"
        android:paddingHorizontal="4dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/viewerTabs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
            <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_100hz" android:textColor="#FFFFFF" android:textSize="7sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/vEq100" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                <TextView android:id="@+id/txtEq100Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
            </FrameLayout>
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
            <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_300hz" android:textColor="#FFFFFF" android:textSize="7sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/vEq300" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                <TextView android:id="@+id/txtEq300Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
            </FrameLayout>
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
            <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_1khz" android:textColor="#FFFFFF" android:textSize="7sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/vEq1k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                <TextView android:id="@+id/txtEq1kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
            </FrameLayout>
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
            <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_3khz" android:textColor="#FFFFFF" android:textSize="7sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/vEq3k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                <TextView android:id="@+id/txtEq3kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
            </FrameLayout>
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
            <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_8khz" android:textColor="#FFFFFF" android:textSize="7sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:includeFontPadding="false"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/vEq8k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00" android:layout_gravity="top|center_horizontal"/>
                <TextView android:id="@+id/txtEq8kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Page 1: FILTER ===== -->
    <LinearLayout
        android:id="@+id/pageFilter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:weightSum="32"
        android:paddingHorizontal="4dp"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/viewerTabs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
            <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_filter_percent" android:textColor="#00FFFF" android:textSize="6sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:lines="2" android:includeFontPadding="false"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/vSliderNoiseFilter" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="1.0" android:value="0.0" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#007F7F" android:layout_gravity="top|center_horizontal"/>
                <TextView android:id="@+id/vTxtFilterValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0pct" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
            </FrameLayout>
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
            <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_rise_time" android:textColor="#00FFFF" android:textSize="6sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:lines="2" android:includeFontPadding="false"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/vSliderNoiseRise" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="3.0" android:value="1.7" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#007F7F" android:layout_gravity="top|center_horizontal"/>
                <TextView android:id="@+id/vTxtRiseValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0ms" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
            </FrameLayout>
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
            <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.4" android:text="@string/label_fall_time" android:textColor="#00FFFF" android:textSize="6sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:lines="2" android:includeFontPadding="false"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.6" android:clipChildren="false" android:clipToPadding="false">
                <com.google.android.material.slider.Slider app:trackCornerSize="0dp" android:id="@+id/vSliderNoiseFall" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="3.0" android:value="2.3" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#007F7F" android:layout_gravity="top|center_horizontal"/>
                <TextView android:id="@+id/vTxtFallValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0ms" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="top|center_horizontal" android:elevation="4dp" android:includeFontPadding="false"/>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Page 2: DISPLAY ===== -->
    <LinearLayout
        android:id="@+id/pageDisplay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/viewerTabs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="4dp"
            android:weightSum="3">
            <Spinner android:id="@+id/vSizeSpinner" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:overlapAnchor="false" />
            <Spinner android:id="@+id/vStepSpinner" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@android:color/transparent" android:overlapAnchor="false" />
            <Button android:id="@+id/btnViewerSweep" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="@string/sweep_off" android:backgroundTint="#FF69B4" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:minWidth="0dp" android:insetTop="0dp" android:insetBottom="0dp" />
        </LinearLayout>

        <Spinner
            android:id="@+id/vBlurSpinner"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:background="@android:color/transparent"
            android:overlapAnchor="false" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
