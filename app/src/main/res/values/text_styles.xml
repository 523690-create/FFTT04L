<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Heading Styles -->
    <style name="TextHeading">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowDx">2</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <!-- Button Text -->
    <style name="TextButton">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- Control Labels (Sliders, Filters) -->
    <style name="TextControlLabel">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- Small Control Labels (for compact sections) -->
    <style name="TextControlLabelSmall">
        <item name="android:textSize">9sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- Numeric Value Display (Monospace-like) -->
    <style name="TextValue">
        <item name="android:textSize">9sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#000000</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Tab Text -->
    <style name="TextTab">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Info/Status Text -->
    <style name="TextStatus">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#AAAAAA</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- Instructions Text -->
    <style name="TextInstructions">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#888888</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>
</resources>

